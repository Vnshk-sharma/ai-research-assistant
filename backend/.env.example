# Copy this file to `.env` inside backend/ and adjust as needed.
# All values shown are the defaults already baked into utils/config.py,
# so an empty/absent .env works fine — this file exists purely to make
# the configurable surface area discoverable.

# --- Embeddings ---------------------------------------------------------
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# --- Reasoning / generation model --------------------------------------
GENERATION_MODEL=google/flan-t5-base
MAX_NEW_TOKENS=512

# --- Chunking ------------------------------------------------------------
CHUNK_SIZE=800
CHUNK_OVERLAP=150
TOP_K_RETRIEVAL=5

# --- CORS (comma-separated origins, parsed as a JSON list by pydantic) --
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# --- Database ------------------------------------------------------------
# Defaults to a local SQLite file under backend/storage/. Point this at a
# Postgres URL (e.g. postgresql://user:pass@host:5432/db) to scale up.
# DB_URL=sqlite:///./storage/research_assistant.db
